# Copy to `.env`. These point clients at the LOCAL LocalStack endpoint (no AWS account needed).
# LocalStack accepts any dummy credentials. Inside docker-compose use http://localstack:4566.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=eu-west-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Kinesis streams (real-time tx in, fraud alerts out). Created by `tflocal apply`.
KINESIS_TX_STREAM=tx-stream
KINESIS_ALERTS_STREAM=alerts-stream

# S3 bucket for datasets + model artifacts
S3_BUCKET=lean-fraud-artifacts

# Experiment tracking
MLFLOW_TRACKING_URI=http://localhost:5000

# Model artifact to load when serving
MODEL_PATH=models/tcn.pt
